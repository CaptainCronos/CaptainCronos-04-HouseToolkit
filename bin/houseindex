#!/usr/bin/env bash
#==============================================================================
#
# Captain Cronos House Toolkit
#
# Command : houseindex
# Purpose : Generate a deterministic Markdown index of repository files.
#
#==============================================================================

set -o errexit
set -o nounset
set -o pipefail

HOUSE_ENTRY_DIR="${BASH_SOURCE[0]%/*}"
[[ "$HOUSE_ENTRY_DIR" != "${BASH_SOURCE[0]}" ]] || HOUSE_ENTRY_DIR="."
if [[ -r "$HOUSE_ENTRY_DIR/../lib/paths.sh" ]]; then
    source "$HOUSE_ENTRY_DIR/../lib/paths.sh"
elif [[ -r "$HOUSE_ENTRY_DIR/.house-toolkit-paths" ]]; then
    source "$HOUSE_ENTRY_DIR/.house-toolkit-paths"
else
    printf 'Unable to locate HouseToolkit path helpers.\n' >&2
    exit 2
fi
SCRIPT_DIR="$(house_path_dir "${BASH_SOURCE[0]}")"

# Path helpers are loaded by the portable bootstrap above.
# shellcheck source=../lib/cli.sh
source "${SCRIPT_DIR}/../lib/cli.sh"
# shellcheck source=../lib/house_toolkit.sh
source "${SCRIPT_DIR}/../lib/house_toolkit.sh"

houseindex_usage() {
    cat <<'EOF'
Usage: houseindex [repository-path]

Generate a deterministic ASSET_INDEX.md. Defaults to this Toolkit repository.
EOF
}

if house_cli_is_help_option "${1:-}"; then
    house_cli_expect_args "$#" 1 1 houseindex_usage
    houseindex_usage
    exit 0
fi
house_cli_expect_args "$#" 0 1 houseindex_usage

INDEX_NAME="ASSET_INDEX.md"
DEFAULT_REPO_ROOT="$(house_find_repo_root)"
TARGET="${1:-$DEFAULT_REPO_ROOT}"

if ! house_is_git_repo "$TARGET"; then
    house_error "Not a Git repository: $TARGET"
    exit 1
fi

REPO_ROOT="$(house_repo_root "$TARGET")"
REPO_NAME="$(house_repo_name "$REPO_ROOT")"
BRANCH="$(house_git_branch "$REPO_ROOT")"
COMMIT="$(house_git_commit "$REPO_ROOT")"
INDEX_PATH="${REPO_ROOT}/${INDEX_NAME}"
TEMP_PATH="$(mktemp "${TMPDIR:-/tmp}/houseindex.XXXXXX")"

cleanup() {
    rm -f "$TEMP_PATH"
}
trap cleanup EXIT

if [[ -z "$BRANCH" ]]; then
    BRANCH="Detached HEAD"
fi

mapfile -d '' REPOSITORY_FILES < <(
    git -C "$REPO_ROOT" ls-files -z --cached --others --exclude-standard |
        sort -z
)

FILES=()
for file in "${REPOSITORY_FILES[@]}"; do
    [[ "$file" == "$INDEX_NAME" ]] && continue
    FILES+=("$file")
done

MARKDOWN_COUNT=0
PNG_COUNT=0
YAML_COUNT=0
TEMPLATE_COUNT=0
OTHER_COUNT=0

declare -A DIRECTORY_SET=()
declare -A TOP_LEVEL_GROUP_SET=()
for file in "${FILES[@]}"; do
    lower_file="${file,,}"

    case "$lower_file" in
        *.md|*.markdown)
            ((MARKDOWN_COUNT += 1))
            ;;
        *.png)
            ((PNG_COUNT += 1))
            ;;
        *.yml|*.yaml)
            ((YAML_COUNT += 1))
            ;;
        *.ott|*.odt|*.ods|*.odp|*.doc|*.docx|*.xls|*.xlsx|*.ppt|*.pptx)
            ((TEMPLATE_COUNT += 1))
            ;;
        *)
            ((OTHER_COUNT += 1))
            ;;
    esac

    if [[ "$file" == */* ]]; then
        TOP_LEVEL_GROUP_SET["${file%%/*}"]=1
        directory="${file%/*}"
        while [[ -n "$directory" ]]; do
            DIRECTORY_SET["$directory"]=1
            [[ "$directory" == */* ]] || break
            directory="${directory%/*}"
        done
    fi
done

DIRECTORY_COUNT="${#DIRECTORY_SET[@]}"

TOP_LEVEL_GROUPS=()
if (( ${#TOP_LEVEL_GROUP_SET[@]} > 0 )); then
    mapfile -t TOP_LEVEL_GROUPS < <(
        printf '%s\n' "${!TOP_LEVEL_GROUP_SET[@]}" | sort
    )
fi

{
    printf '# %s Asset Index\n\n' "$REPO_NAME"
    printf '> Generated by Captain Cronos House Toolkit. Do not edit manually.\n\n'

    printf '## Repository Information\n\n'
    printf '| Field | Value |\n'
    printf '|---|---|\n'
    printf '| Repository | `%s` |\n' "$REPO_NAME"
    printf '| Branch | `%s` |\n' "$BRANCH"
    printf '| Commit | `%s` |\n' "$COMMIT"
    printf '| Index format | Deterministic |\n\n'

    printf '## Summary\n\n'
    printf '| Category | Count |\n'
    printf '|---|---:|\n'
    printf '| Repository files | %d |\n' "${#FILES[@]}"
    printf '| Directories represented | %d |\n' "$DIRECTORY_COUNT"
    printf '| Markdown | %d |\n' "$MARKDOWN_COUNT"
    printf '| PNG images | %d |\n' "$PNG_COUNT"
    printf '| YAML configuration | %d |\n' "$YAML_COUNT"
    printf '| Office/template files | %d |\n' "$TEMPLATE_COUNT"
    printf '| Other files | %d |\n\n' "$OTHER_COUNT"

    printf '## Files by Top-Level Directory\n\n'

    root_file_count=0
    for file in "${FILES[@]}"; do
        if [[ "$file" != */* ]]; then
            if (( root_file_count == 0 )); then
                printf '### Repository Root\n\n'
            fi
            printf -- '- `%s`\n' "$file"
            ((root_file_count += 1))
        fi
    done

    for group in "${TOP_LEVEL_GROUPS[@]}"; do
        (( root_file_count == 0 )) || printf '\n'
        printf '### %s\n\n' "$group"
        for file in "${FILES[@]}"; do
            [[ "$file" == "$group"/* ]] || continue
            printf -- '- `%s`\n' "$file"
        done
        root_file_count=1
    done

    if [[ ${#FILES[@]} -eq 0 ]]; then
        printf '_No tracked or unignored files found._\n'
    fi
} > "$TEMP_PATH"

if [[ ! -e "$INDEX_PATH" ]]; then
    mv "$TEMP_PATH" "$INDEX_PATH"
    RESULT="Created"
elif cmp -s "$TEMP_PATH" "$INDEX_PATH"; then
    rm -f "$TEMP_PATH"
    RESULT="Unchanged"
else
    mv "$TEMP_PATH" "$INDEX_PATH"
    RESULT="Updated"
fi
trap - EXIT

house_banner
house_section "House Index Complete"
house_kv "Repository" "$REPO_NAME"
house_kv "Indexed Files" "${#FILES[@]}"
house_kv "Directories" "$DIRECTORY_COUNT"
house_kv "Output" "$INDEX_PATH"
house_kv "Status" "$RESULT"
printf '\n'
