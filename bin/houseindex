#!/usr/bin/env bash
#==============================================================================
#
# Captain Cronos House Toolkit
#
# Command : houseindex
# Purpose : Generate a deterministic Markdown index of tracked repository files.
#
#==============================================================================

set -o errexit
set -o nounset
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=../lib/house_toolkit.sh
source "${SCRIPT_DIR}/../lib/house_toolkit.sh"

TARGET="${1:-$PWD}"
INDEX_NAME="ASSET_INDEX.md"

if ! house_is_git_repo "$TARGET"; then
    house_error "Not a Git repository: $TARGET"
    exit 1
fi

REPO_ROOT="$(house_repo_root "$TARGET")"
REPO_NAME="$(house_repo_name "$REPO_ROOT")"
BRANCH="$(house_git_branch "$REPO_ROOT")"
COMMIT="$(house_git_commit "$REPO_ROOT")"
INDEX_PATH="${REPO_ROOT}/${INDEX_NAME}"
TEMP_PATH="$(mktemp "${INDEX_PATH}.tmp.XXXXXX")"

cleanup() {
    rm -f "$TEMP_PATH"
}
trap cleanup EXIT

if [[ -z "$BRANCH" ]]; then
    BRANCH="Detached HEAD"
fi

mapfile -d '' TRACKED_FILES < <(
    git -C "$REPO_ROOT" ls-files -z --cached --others --exclude-standard |
        sort -z
)

FILTERED_FILES=()
for file in "${TRACKED_FILES[@]}"; do
    [[ "$file" == "$INDEX_NAME" ]] && continue
    FILTERED_FILES+=("$file")
done

{
    printf '# %s Asset Index\n\n' "$REPO_NAME"
    printf '> Generated by Captain Cronos House Toolkit. Do not edit manually.\n\n'

    printf '## Repository\n\n'
    printf -- '- **Name:** `%s`\n' "$REPO_NAME"
    printf -- '- **Branch:** `%s`\n' "$BRANCH"
    printf -- '- **Commit:** `%s`\n' "$COMMIT"
    printf -- '- **Indexed files:** %d\n\n' "${#FILTERED_FILES[@]}"

    printf '## Files by Top-Level Directory\n\n'

    current_group=''
    for file in "${FILTERED_FILES[@]}"; do
        if [[ "$file" == */* ]]; then
            group="${file%%/*}"
        else
            group='Repository Root'
        fi

        if [[ "$group" != "$current_group" ]]; then
            [[ -n "$current_group" ]] && printf '\n'
            printf '### %s\n\n' "$group"
            current_group="$group"
        fi

        printf -- '- `%s`\n' "$file"
    done

    if [[ ${#FILTERED_FILES[@]} -eq 0 ]]; then
        printf '_No tracked or unignored files found._\n'
    fi
} > "$TEMP_PATH"

mv "$TEMP_PATH" "$INDEX_PATH"
trap - EXIT

house_success "Created ${INDEX_PATH}"
house_info "Indexed ${#FILTERED_FILES[@]} files."
