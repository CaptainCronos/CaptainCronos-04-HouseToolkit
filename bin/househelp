#!/usr/bin/env bash
#==============================================================================
#
# Captain Cronos House Toolkit
# Command : househelp
#
#==============================================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=../lib/paths.sh
source "${SCRIPT_DIR}/../lib/paths.sh"
# shellcheck source=../lib/house_toolkit.sh
source "${SCRIPT_DIR}/../lib/house_toolkit.sh"

house_banner

house_section "Available Commands"

house_kv "househelp"     "Display this help screen."
house_kv "housestats"    "Display repository statistics."
house_kv "houseindex"    "Generate ASSET_INDEX.md for a repository."
house_kv "housevalidate" "Validate Toolkit or House repository structure."
house_kv "housemember"   "Manage HouseToolkit members."
house_kv "housecard"     "Initialize HouseCard metadata for a member."
house_kv "housebuild"    "Validate HouseCard build readiness."
house_kv "housepreview"  "Preview generated HouseCards."
house_kv "houserelease"  "Prepare and inspect release packages."

house_section "Planned Commands"

printf "housepublish\n"
