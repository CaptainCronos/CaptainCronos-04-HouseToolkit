#!/usr/bin/env bash
#==============================================================================
#
# Captain Cronos House Toolkit
# Command : houserelease
# Purpose : Prepare HouseToolkit release packages.
#
#==============================================================================

set -o errexit
set -o nounset
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=../lib/paths.sh
source "${SCRIPT_DIR}/../lib/paths.sh"
# shellcheck source=../lib/cli.sh
source "${SCRIPT_DIR}/../lib/cli.sh"

REPO_ROOT="$(house_cli_repo_root)"

# shellcheck source=../lib/house_toolkit.sh
source "${SCRIPT_DIR}/../lib/house_toolkit.sh"
# shellcheck source=../lib/validation.sh
source "${SCRIPT_DIR}/../lib/validation.sh"
# shellcheck source=../lib/houserelease.sh
source "${SCRIPT_DIR}/../lib/houserelease.sh"

case "${1:-}" in
    ""|-h|--help|help)
        house_cli_expect_args "$#" 0 1 houserelease_usage
        houserelease_usage
        ;;
    status)
        house_cli_expect_args "$#" 1 1 houserelease_usage
        houserelease_status "$REPO_ROOT"
        ;;
    list)
        house_cli_expect_args "$#" 1 1 houserelease_usage
        houserelease_list "$REPO_ROOT"
        ;;
    clean)
        house_cli_expect_args "$#" 1 1 houserelease_usage
        houserelease_clean "$REPO_ROOT"
        ;;
    build)
        house_cli_expect_args "$#" 1 1 houserelease_usage
        houserelease_build "$REPO_ROOT"
        ;;
    *)
        house_cli_usage_error houserelease_usage
        ;;
esac
