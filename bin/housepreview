#!/usr/bin/env bash
#==============================================================================
#
# Captain Cronos House Toolkit
# Command : housepreview
# Purpose : Prepare validated release handoffs and inspect preview readiness.
#
#==============================================================================

set -o errexit
set -o nounset
set -o pipefail

HOUSE_ENTRY_DIR="${BASH_SOURCE[0]%/*}"
[[ "$HOUSE_ENTRY_DIR" != "${BASH_SOURCE[0]}" ]] || HOUSE_ENTRY_DIR="."
if [[ -r "$HOUSE_ENTRY_DIR/../lib/paths.sh" ]]; then
    source "$HOUSE_ENTRY_DIR/../lib/paths.sh"
elif [[ -r "$HOUSE_ENTRY_DIR/.house-toolkit-paths" ]]; then
    source "$HOUSE_ENTRY_DIR/.house-toolkit-paths"
else
    printf 'Unable to locate HouseToolkit path helpers.\n' >&2
    exit 2
fi
SCRIPT_DIR="$(house_path_dir "${BASH_SOURCE[0]}")"

# Path helpers are loaded by the portable bootstrap above.
# shellcheck source=../lib/cli.sh
source "${SCRIPT_DIR}/../lib/cli.sh"

REPO_ROOT="$(house_cli_repo_root)"

# shellcheck source=../lib/house_toolkit.sh
source "${SCRIPT_DIR}/../lib/house_toolkit.sh"
# shellcheck source=../lib/validation.sh
source "${SCRIPT_DIR}/../lib/validation.sh"
# shellcheck source=../lib/housepreview.sh
source "${SCRIPT_DIR}/../lib/housepreview.sh"

case "${1:-}" in
    ""|-h|--help|help)
        house_cli_expect_args "$#" 0 1 housepreview_usage
        housepreview_usage
        ;;
    status)
        house_cli_expect_args "$#" 1 1 housepreview_usage
        housepreview_status "$REPO_ROOT"
        ;;
    list)
        house_cli_expect_args "$#" 1 1 housepreview_usage
        housepreview_list "$REPO_ROOT"
        ;;
    clean)
        house_cli_expect_args "$#" 1 1 housepreview_usage
        housepreview_clean
        ;;
    build)
        house_cli_expect_args "$#" 1 1 housepreview_usage
        housepreview_build "$REPO_ROOT"
        ;;
    member)
        house_cli_expect_args "$#" 2 2 housepreview_usage
        housepreview_member "$REPO_ROOT" "$2"
        ;;
    *)
        house_cli_expect_args "$#" 1 2 housepreview_usage
        force=0
        if (( $# == 2 )) && [[ "$2" != "--force" ]]; then
            house_cli_usage_error housepreview_usage
        elif (( $# == 2 )); then
            force=1
        fi
        housepreview_create "$REPO_ROOT" "$1" "$force"
        ;;
esac
