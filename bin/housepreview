#!/usr/bin/env bash
#==============================================================================
#
# Captain Cronos House Toolkit
# Command : housepreview
# Purpose : Inspect and validate HouseCard preview readiness.
#
#==============================================================================

set -o errexit
set -o nounset
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=../lib/paths.sh
source "${SCRIPT_DIR}/../lib/paths.sh"

if ! REPO_ROOT="$(house_find_repo_root)"; then
    printf ' FAIL  Repository                         not recognized as HouseToolkit\n' >&2
    exit 2
fi

# shellcheck source=../lib/house_toolkit.sh
source "${SCRIPT_DIR}/../lib/house_toolkit.sh"
# shellcheck source=../lib/validation.sh
source "${SCRIPT_DIR}/../lib/validation.sh"
# shellcheck source=../lib/housepreview.sh
source "${SCRIPT_DIR}/../lib/housepreview.sh"

case "${1:-}" in
    "")
        housepreview_usage
        ;;
    status)
        [[ $# -eq 1 ]] || housepreview_usage_error
        housepreview_status "$REPO_ROOT"
        ;;
    list)
        [[ $# -eq 1 ]] || housepreview_usage_error
        housepreview_list "$REPO_ROOT"
        ;;
    clean)
        [[ $# -eq 1 ]] || housepreview_usage_error
        housepreview_clean
        ;;
    build)
        [[ $# -eq 1 ]] || housepreview_usage_error
        housepreview_build "$REPO_ROOT"
        ;;
    member)
        [[ $# -eq 2 ]] || housepreview_usage_error
        housepreview_member "$REPO_ROOT" "$2"
        ;;
    *)
        housepreview_usage_error
        ;;
esac
