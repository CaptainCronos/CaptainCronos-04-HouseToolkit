#!/usr/bin/env bash
#==============================================================================
# Captain Cronos House Toolkit
# Command : housebuild
# Purpose : Build validated HouseCard handoffs and inspect readiness.
#==============================================================================

set -o errexit
set -o nounset
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

# shellcheck source=../lib/paths.sh
source "${SCRIPT_DIR}/../lib/paths.sh"
# shellcheck source=../lib/cli.sh
source "${SCRIPT_DIR}/../lib/cli.sh"

REPO_ROOT="$(house_cli_repo_root)"

# shellcheck source=../lib/house_toolkit.sh
source "${SCRIPT_DIR}/../lib/house_toolkit.sh"
# shellcheck source=../lib/validation.sh
source "${SCRIPT_DIR}/../lib/validation.sh"
# shellcheck source=../lib/housebuild.sh
source "${SCRIPT_DIR}/../lib/housebuild.sh"

case "${1:-}" in
    ""|-h|--help|help)
        house_cli_expect_args "$#" 0 1 housebuild_usage
        housebuild_usage
        ;;
    status)
        house_cli_expect_args "$#" 1 1 housebuild_usage
        housebuild_status "$REPO_ROOT"
        ;;
    clean)
        house_cli_expect_args "$#" 1 1 housebuild_usage
        housebuild_clean
        ;;
    build)
        house_cli_expect_args "$#" 1 1 housebuild_usage
        housebuild_build "$REPO_ROOT"
        ;;
    member)
        house_cli_expect_args "$#" 2 2 housebuild_usage
        housebuild_member "$REPO_ROOT" "$2"
        ;;
    all)
        house_cli_expect_args "$#" 1 1 housebuild_usage
        housebuild_all "$REPO_ROOT"
        ;;
    *)
        house_cli_expect_args "$#" 1 2 housebuild_usage
        force=0
        if (( $# == 2 )) && [[ "$2" != "--force" ]]; then
            house_cli_usage_error housebuild_usage
        elif (( $# == 2 )); then
            force=1
        fi
        housebuild_create "$REPO_ROOT" "$1" "$force"
        ;;
esac
