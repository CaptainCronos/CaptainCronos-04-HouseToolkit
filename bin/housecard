#!/usr/bin/env bash
#==============================================================================
#
# Captain Cronos House Toolkit
# Command : housecard
# Purpose : Initialize HouseCard metadata from a member profile.
#
#==============================================================================

set -o errexit
set -o nounset
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=../lib/paths.sh
source "${SCRIPT_DIR}/../lib/paths.sh"

if ! REPO_ROOT="$(house_find_repo_root)"; then
    printf ' FAIL  Repository                         not recognized as HouseToolkit\n' >&2
    exit 2
fi

# shellcheck source=../lib/house_toolkit.sh
source "${SCRIPT_DIR}/../lib/house_toolkit.sh"
# shellcheck source=../lib/validation.sh
source "${SCRIPT_DIR}/../lib/validation.sh"
# shellcheck source=../lib/housecard.sh
source "${SCRIPT_DIR}/../lib/housecard.sh"

validation_exit() {
    local exit_code

    set +o errexit
    house_validation_summary
    exit_code=$?
    set -o errexit
    exit "$exit_code"
}

if [[ "${1:-}" != "create" || $# -ne 2 ]]; then
    printf 'Usage: housecard create <member-id>\n' >&2
    exit 2
fi

requested_member_id="$2"

house_banner
house_section "HouseCard Create"
house_validation_reset

if ! house_is_git_repo "$REPO_ROOT"; then
    house_validation_result FAIL "Git repository" "$REPO_ROOT"
    validation_exit
fi
house_validation_result PASS "Git repository" "$REPO_ROOT"

if house_detect_repository_profile "$REPO_ROOT"; then
    house_validation_result PASS "Repository profile" \
        "${HOUSE_REPOSITORY_PROFILE} (${HOUSE_PROFILE_SOURCE})"
else
    case "$HOUSE_PROFILE_SOURCE" in
        "conflicting markers")
            detail="both repository markers are present"
            ;;
        *)
            detail="repository profile is not recognized"
            ;;
    esac
    house_validation_result FAIL "Repository profile" "$detail"
    validation_exit
fi

house_validate_repository "$REPO_ROOT" "$HOUSE_REPOSITORY_PROFILE"
if (( HOUSE_FAIL_COUNT > 0 )); then
    validation_exit
fi

if [[ ! "$requested_member_id" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]]; then
    house_validation_result FAIL "Member ID" "invalid member identifier"
    validation_exit
fi

member_id="${requested_member_id,,}"
member_dir="$(house_member_dir "$member_id")"
profile_path="${member_dir}/profile.yml"
card_dir="$(house_member_card_dir "$member_id")"
card_path="${card_dir}/card.yml"
readme_path="${card_dir}/README.md"

if [[ ! -d "$member_dir" ]]; then
    house_validation_result FAIL "Member '${member_id}'" "member does not exist"
    validation_exit
fi
house_validation_result PASS "Member '${member_id}'" "$member_dir"

if [[ ! -f "$profile_path" ]]; then
    house_validation_result FAIL "Member profile.yml" "missing required file"
    validation_exit
fi
house_validation_result PASS "Member profile.yml" "$profile_path"

profile_member_id="$(housecard_profile_member_value "$profile_path" id)"
member_uuid="$(housecard_profile_member_value "$profile_path" uuid)"
display_name="$(housecard_profile_member_value "$profile_path" display_name)"

if [[ -z "$profile_member_id" || -z "$member_uuid" || -z "$display_name" ]]; then
    house_validation_result FAIL "Member metadata" \
        "member.id, member.uuid, and member.display_name are required"
    validation_exit
fi

if [[ "$profile_member_id" != "$member_id" ]]; then
    house_validation_result FAIL "Member metadata" \
        "profile member ID '${profile_member_id}' does not match '${member_id}'"
    validation_exit
fi
house_validation_result PASS "Member metadata" "id, uuid, display_name"

if [[ -d "$card_dir" ]]; then
    house_validation_result WARN "HouseCard '${member_id}'" \
        "already initialized; existing files were not changed"
    validation_exit
elif [[ -e "$card_dir" ]]; then
    house_validation_result FAIL "HouseCard '${member_id}'" \
        "card path exists and is not a directory"
    validation_exit
fi

mkdir "$card_dir"
housecard_write_card "$card_path" "$profile_member_id" "$member_uuid" "$display_name"
housecard_write_readme "$readme_path"

house_validation_result PASS "card/card.yml" "created"
house_validation_result PASS "card/README.md" "created"
validation_exit
