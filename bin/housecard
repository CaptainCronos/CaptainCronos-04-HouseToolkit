#!/usr/bin/env bash
#==============================================================================
#
# Captain Cronos House Toolkit
# Command : housecard
# Purpose : Initialize HouseCard metadata from a member profile.
#
#==============================================================================

set -o errexit
set -o nounset
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

# shellcheck source=../lib/paths.sh
source "${SCRIPT_DIR}/../lib/paths.sh"
# shellcheck source=../lib/cli.sh
source "${SCRIPT_DIR}/../lib/cli.sh"

REPO_ROOT="$(house_cli_repo_root)"

# shellcheck source=../lib/house_toolkit.sh
source "${SCRIPT_DIR}/../lib/house_toolkit.sh"
# shellcheck source=../lib/validation.sh
source "${SCRIPT_DIR}/../lib/validation.sh"
# shellcheck source=../lib/housemember.sh
source "${SCRIPT_DIR}/../lib/housemember.sh"
# shellcheck source=../lib/housecard.sh
source "${SCRIPT_DIR}/../lib/housecard.sh"

housecard_usage() {
    cat <<'EOF'
Usage: housecard create <member-id> [--force]

Create a complete HouseCard workspace for an existing member. Existing cards
are preserved unless --force is supplied.
EOF
}

validation_exit() {
    local exit_code

    set +o errexit
    house_validation_summary
    exit_code=$?
    set -o errexit
    exit "$exit_code"
}

if house_cli_is_help "${1:-}"; then
    house_cli_expect_args "$#" 1 1 housecard_usage
    housecard_usage
    exit 0
fi

if [[ "${1:-}" != "create" ]]; then
    house_cli_usage_error housecard_usage
fi
house_cli_expect_args "$#" 2 3 housecard_usage

force=0
case "$#:$2:${3:-}" in
    2:--force:*)
        house_cli_usage_error housecard_usage
        ;;
    2:*)
        requested_member_id="$2"
        ;;
    3:--force:*)
        requested_member_id="$3"
        force=1
        ;;
    3:*:--force)
        requested_member_id="$2"
        force=1
        ;;
    *)
        house_cli_usage_error housecard_usage
        ;;
esac

house_banner
house_section "HouseCard Create"
house_validation_reset

if ! house_is_git_repo "$REPO_ROOT"; then
    house_validation_result FAIL "Git repository" "$REPO_ROOT"
    validation_exit
fi
house_validation_result PASS "Git repository" "$REPO_ROOT"

if house_detect_repository_profile "$REPO_ROOT"; then
    house_validation_result PASS "Repository profile" \
        "${HOUSE_REPOSITORY_PROFILE} (${HOUSE_PROFILE_SOURCE})"
else
    case "$HOUSE_PROFILE_SOURCE" in
        "conflicting markers")
            detail="both repository markers are present"
            ;;
        *)
            detail="repository profile is not recognized"
            ;;
    esac
    house_validation_result FAIL "Repository profile" "$detail"
    validation_exit
fi

house_validate_repository "$REPO_ROOT" "$HOUSE_REPOSITORY_PROFILE"
if (( HOUSE_FAIL_COUNT > 0 )); then
    validation_exit
fi

if housecard_create "$requested_member_id" "$force"; then
    house_validation_result PASS "Member '${HOUSE_MEMBER_ID}'" \
        "$HOUSE_MEMBER_DIR"
    house_validation_result PASS "Member profile.yml" \
        "version 1; id, uuid, display_name"
    house_validation_result PASS "HouseCard workspace" \
        "$HOUSE_CARD_DIR"
    house_validation_result PASS "card/card.yml" "$HOUSE_CARD_RESULT"
    house_validation_result PASS "card/README.md" "$HOUSE_CARD_RESULT"
    house_validation_result PASS "card/assets/" "placeholder ready"
    house_validation_result PASS "card/templates/" "placeholder ready"
else
    result=$?
    if (( result == 1 )); then
        house_validation_result WARN "HouseCard '${HOUSE_MEMBER_ID}'" \
            "$HOUSE_CARD_ERROR"
    else
        house_validation_result FAIL "HouseCard" "$HOUSE_CARD_ERROR"
    fi
fi
validation_exit
