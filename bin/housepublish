#!/usr/bin/env bash
#==============================================================================
# Captain Cronos House Toolkit
# Command : housepublish
# Purpose : Inspect publishing readiness for an already-built release.
#==============================================================================

set -o errexit
set -o nounset
set -o pipefail

HOUSE_ENTRY_DIR="${BASH_SOURCE[0]%/*}"
[[ "$HOUSE_ENTRY_DIR" != "${BASH_SOURCE[0]}" ]] || HOUSE_ENTRY_DIR="."
if [[ -r "$HOUSE_ENTRY_DIR/../lib/paths.sh" ]]; then
    source "$HOUSE_ENTRY_DIR/../lib/paths.sh"
elif [[ -r "$HOUSE_ENTRY_DIR/.house-toolkit-paths" ]]; then
    source "$HOUSE_ENTRY_DIR/.house-toolkit-paths"
else
    printf 'Unable to locate HouseToolkit path helpers.\n' >&2
    exit 2
fi
SCRIPT_DIR="$(house_path_dir "${BASH_SOURCE[0]}")"

# Path helpers are loaded by the portable bootstrap above.
# shellcheck source=../lib/cli.sh
source "${SCRIPT_DIR}/../lib/cli.sh"

REPO_ROOT="$(house_cli_repo_root)"

# shellcheck source=../lib/house_toolkit.sh
source "${SCRIPT_DIR}/../lib/house_toolkit.sh"
# shellcheck source=../lib/validation.sh
source "${SCRIPT_DIR}/../lib/validation.sh"
# shellcheck source=../lib/housepublish.sh
source "${SCRIPT_DIR}/../lib/housepublish.sh"

case "${1:-}" in
    ""|-h|--help|help)
        house_cli_expect_args "$#" 0 1 housepublish_usage
        housepublish_usage
        ;;
    status)
        house_cli_expect_args "$#" 1 1 housepublish_usage
        housepublish_status "$REPO_ROOT"
        ;;
    list)
        house_cli_expect_args "$#" 1 1 housepublish_usage
        housepublish_list "$REPO_ROOT"
        ;;
    validate)
        house_cli_expect_args "$#" 1 1 housepublish_usage
        housepublish_validate "$REPO_ROOT"
        ;;
    publish)
        house_cli_expect_args "$#" 1 1 housepublish_usage
        housepublish_publish
        ;;
    clean)
        house_cli_expect_args "$#" 1 1 housepublish_usage
        housepublish_clean
        ;;
    *)
        house_cli_usage_error housepublish_usage
        ;;
esac
