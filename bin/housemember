#!/usr/bin/env bash
#==============================================================================
#
# Captain Cronos House Toolkit
# Command : housemember
# Purpose : Manage HouseToolkit members.
#
#==============================================================================

set -o errexit
set -o nounset
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=../lib/paths.sh
source "${SCRIPT_DIR}/../lib/paths.sh"

fail() {
    printf 'FAIL\n\n%s\n' "$1" >&2
    exit 2
}

if [[ "${1:-}" != "add" || $# -ne 1 ]]; then
    printf 'Usage: housemember add\n' >&2
    exit 2
fi

printf 'Member ID: '
if ! IFS= read -r raw_member_id; then
    fail "Member ID is required."
fi

display_name="$(printf '%s' "$raw_member_id" |
    sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"

[[ -n "$display_name" ]] || fail "Member ID is required."
[[ "$display_name" != *[[:space:]]* ]] || fail "Member ID cannot contain spaces."

if [[ ! "$display_name" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]]; then
    fail "Member ID contains illegal filesystem characters."
fi

member_id="${display_name,,}"
members_dir="$(house_members_dir)"
member_dir="${members_dir}/${member_id}"

if [[ -e "$member_dir" ]]; then
    fail "Member '${member_id}' already exists."
fi

member_uuid="$(uuidgen)"

mkdir -p "$members_dir"
if ! mkdir "$member_dir"; then
    if [[ -e "$member_dir" ]]; then
        fail "Member '${member_id}' already exists."
    fi
    fail "Unable to create member '${member_id}'."
fi

mkdir -p \
    "$member_dir/assets" \
    "$member_dir/documents" \
    "$member_dir/photos" \
    "$member_dir/signatures" \
    "$member_dir/social"

printf '%s\n' \
    'version: 1' \
    '' \
    'member:' \
    "  id: ${member_id}" \
    "  uuid: ${member_uuid}" \
    "  display_name: ${display_name}" \
    '' \
    'status:' \
    '  active: true' \
    '' \
    'contact:' \
    '  email:' \
    '  phone:' \
    '' \
    'branding:' \
    '  logo:' \
    '  primary_color:' \
    '' \
    'notes: |' \
    '' \
    'created:' \
    '  created_by: HouseToolkit' \
    '  created_date:' > "$member_dir/profile.yml"

printf '%s\n' \
    "# ${display_name}" \
    '' \
    'HouseToolkit Member' \
    '' \
    'This directory contains all assets and metadata for this member.' \
    '' \
    'Generated by HouseToolkit.' > "$member_dir/README.md"

printf "Member '%s' created.\n" "$member_id"
