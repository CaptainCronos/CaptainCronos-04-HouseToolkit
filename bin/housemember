#!/usr/bin/env bash
#==============================================================================
#
# Captain Cronos House Toolkit
# Command : housemember
# Purpose : Manage HouseToolkit members.
#
#==============================================================================

set -o errexit
set -o nounset
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

# shellcheck source=../lib/paths.sh
source "${SCRIPT_DIR}/../lib/paths.sh"
# shellcheck source=../lib/cli.sh
source "${SCRIPT_DIR}/../lib/cli.sh"
# shellcheck source=../lib/housemember.sh
source "${SCRIPT_DIR}/../lib/housemember.sh"

housemember_usage() {
    cat <<'EOF'
Usage: housemember add [member-id]

Initialize a member profile and asset directories. When member-id is omitted,
prompt for it interactively.
EOF
}

fail() {
    printf 'FAIL\n\n%s\n' "$1" >&2
    exit 2
}

if house_cli_is_help "${1:-}"; then
    house_cli_expect_args "$#" 1 1 housemember_usage
    housemember_usage
    exit 0
fi

if [[ "${1:-}" != "add" ]]; then
    house_cli_usage_error housemember_usage
fi
house_cli_expect_args "$#" 1 2 housemember_usage

if (( $# == 2 )); then
    raw_member_id="$2"
else
    printf 'Member ID: '
    if ! IFS= read -r raw_member_id; then
        fail "Member ID is required."
    fi
fi

if ! house_member_create "$raw_member_id"; then
    fail "$HOUSE_MEMBER_ERROR"
fi

printf "Member '%s' created.\n" "$HOUSE_MEMBER_ID"
