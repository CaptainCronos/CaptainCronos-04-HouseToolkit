#!/usr/bin/env bash
#==============================================================================
#
# Captain Cronos House Toolkit
#
# Command : housestats
# Purpose : Display repository statistics.
#
#==============================================================================

set -o errexit
set -o nounset
set -o pipefail

HOUSE_ENTRY_DIR="${BASH_SOURCE[0]%/*}"
[[ "$HOUSE_ENTRY_DIR" != "${BASH_SOURCE[0]}" ]] || HOUSE_ENTRY_DIR="."
if [[ -r "$HOUSE_ENTRY_DIR/../lib/paths.sh" ]]; then
    source "$HOUSE_ENTRY_DIR/../lib/paths.sh"
elif [[ -r "$HOUSE_ENTRY_DIR/.house-toolkit-paths" ]]; then
    source "$HOUSE_ENTRY_DIR/.house-toolkit-paths"
else
    printf 'Unable to locate HouseToolkit path helpers.\n' >&2
    exit 2
fi
SCRIPT_DIR="$(house_path_dir "${BASH_SOURCE[0]}")"

# Path helpers are loaded by the portable bootstrap above.
# shellcheck source=../lib/cli.sh
source "${SCRIPT_DIR}/../lib/cli.sh"
# shellcheck source=../lib/house_toolkit.sh
source "${SCRIPT_DIR}/../lib/house_toolkit.sh"

housestats_usage() {
    cat <<'EOF'
Usage: housestats [repository-path]

Display Git and filesystem statistics. Defaults to this Toolkit repository.
EOF
}

if house_cli_is_help_option "${1:-}"; then
    house_cli_expect_args "$#" 1 1 housestats_usage
    housestats_usage
    exit 0
fi
house_cli_expect_args "$#" 0 1 housestats_usage

DEFAULT_REPO_ROOT="$(house_find_repo_root)"
TARGET="${1:-$DEFAULT_REPO_ROOT}"

if ! house_is_git_repo "$TARGET"; then
    house_error "Not a Git repository: $TARGET"
    exit 1
fi

REPO_ROOT="$(house_repo_root "$TARGET")"
REPO_NAME="$(house_repo_name "$REPO_ROOT")"
BRANCH="$(house_git_branch "$REPO_ROOT")"
COMMIT="$(house_git_commit "$REPO_ROOT")"

if [[ -z "$BRANCH" ]]; then
    BRANCH="Detached HEAD"
fi

if house_git_clean "$REPO_ROOT"; then
    STATUS="Clean"
else
    STATUS="Modified"
fi

house_banner

house_section "Repository"
house_kv "Name" "$REPO_NAME"
house_kv "Path" "$REPO_ROOT"
house_kv "Branch" "$BRANCH"
house_kv "Status" "$STATUS"
house_kv "Commit" "$COMMIT"

house_collect_stats "$REPO_ROOT"
house_section "Statistics"
house_kv "Directories" "$HOUSE_STAT_DIRECTORIES"
house_kv "Files" "$HOUSE_STAT_FILES"
house_kv "Markdown Files" "$HOUSE_STAT_MARKDOWN"
house_kv "PNG Files" "$HOUSE_STAT_PNG"
house_kv "Repository Size" "$(house_repository_size "$REPO_ROOT")"

printf "\n"
