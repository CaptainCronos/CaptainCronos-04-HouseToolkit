#!/usr/bin/env bash
#==============================================================================
#
# Captain Cronos House Toolkit
#
# Command : housevalidate
# Purpose : Detect and validate Toolkit and House repositories.
#
#==============================================================================

set -o errexit
set -o nounset
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=../lib/house_toolkit.sh
source "${SCRIPT_DIR}/../lib/house_toolkit.sh"
# shellcheck source=../lib/validation.sh
source "${SCRIPT_DIR}/../lib/validation.sh"

TARGET="${1:-$PWD}"

house_banner
house_section "House Validation"
house_validation_reset

if ! house_is_git_repo "$TARGET"; then
    house_validation_result FAIL "Git repository" "$TARGET"
    house_validation_summary
    exit $?
fi

REPO_ROOT="$(house_repo_root "$TARGET")"
REPO_NAME="$(house_repo_name "$REPO_ROOT")"

house_kv "Repository" "$REPO_NAME"
house_kv "Path" "$REPO_ROOT"

house_section "Repository"
house_validation_result PASS "Git repository"

if house_git_clean "$REPO_ROOT"; then
    house_validation_result PASS "Working tree" "clean"
else
    house_validation_result WARN "Working tree" "uncommitted or untracked changes"
fi

if house_detect_repository_profile "$REPO_ROOT"; then
    house_validation_result INFO "Repository profile" \
        "${HOUSE_REPOSITORY_PROFILE} (${HOUSE_PROFILE_SOURCE})"
else
    case "$HOUSE_PROFILE_SOURCE" in
        "conflicting markers")
            house_validation_result FAIL "Repository profile" \
                "both .house-toolkit and .house-repository are present"
            ;;
        *)
            house_validation_result FAIL "Repository profile" \
                "not recognized; add .house-toolkit or .house-repository"
            ;;
    esac

    house_validation_summary
    exit $?
fi

house_validate_repository "$REPO_ROOT" "$HOUSE_REPOSITORY_PROFILE"
house_validation_summary
